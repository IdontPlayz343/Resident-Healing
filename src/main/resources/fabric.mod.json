	"authors": [
		"PRIDE SEE-BOT"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/pre-alpha-resident-healing",
		"sources": "https://github.com/IdontPlayz343/Resident-Healing"
	},
	"license": "CC0-1.0",
	"icon": "assets/resident_healing/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"pride_seebot.resident_healing.ResidentHealing"
		],
		"client": [
			"pride_seebot.resident_healing.client.ResidentHealingClient"
		],
		"fabric-datagen": [
			"pride_seebot.resident_healing.client.ResidentHealingDataGenerator"
		]
	},
	"mixins": [
		"resident_healing.mixins.json",
		{
			"config": "resident_healing.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.6",
		"minecraft": "1.21.1",
		"java": ">=21",
		"fabric-api": "*"
